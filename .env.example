# Get your free Groq API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Password to access analytics dashboard at /api/analytics/stats
ANALYTICS_PASSWORD=your_admin_password_here

# Port for the backend server (optional, defaults to 3001)
PORT=3001

# Supabase — for Brand Intelligence Capture (leads storage)
# Get these from https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
